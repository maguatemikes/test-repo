# ---------- Database ----------
# MySQL connection. Use TLS for the production deployment.
# Format: mysql://user:pass@host:port/database?ssl=true
DATABASE_URL=mysql://dev:CHANGE_ME@DB_SERVER_IP:3206/omnc

# ---------- Auth (Clerk) ----------
# Get these from https://dashboard.clerk.com after creating an application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---------- NetX backend (AI agent service, etc.) ----------
# Internal HTTP base URL to the .NET API. Must be reachable from this server.
NETX_API_BASE_URL=http://api.internal:5000
NETX_API_INTERNAL_TOKEN=change_me_internal_signing_key

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
